#include <stdio.h>

int main()
{
    int n,s=0,i;
    scanf("%d",&n);
   int a[n];
   for(int i=0;i<n;i++){
       scanf("%d",&a[i]);
   }
    for(int i=0;i<n;i++){
        if(i==0)
        printf("%d ",a[i+1]+a[n-1]);
        else if(i==n-1)
        printf("%d ",a[i-1]+a[0]);
        else
        printf("%d ",a[i-1]+a[i+1]);
    }

    return 0;
}
